# Database (use absolute path for Next.js API routes)
# Replace /path/to/project with your actual project directory
DATABASE_URL="file:/path/to/project/devtrail/prisma/dev.db"

# NextAuth.js Configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=generate_a_secret_with_openssl_rand_base64_32

# GitHub OAuth App
# Create at: https://github.com/settings/developers > OAuth Apps > New OAuth App
# Homepage URL: http://localhost:4000
# Callback URL: http://localhost:4000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Optional: Disable auth for development/rollback (default: auth enabled)
# AUTH_ENABLED=false

# AWS Bedrock (Claude is invoked via Bedrock; no Anthropic API key needed)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# Optional: required when using STS / assumed-role / MFA temporary credentials
# AWS_SESSION_TOKEN=your_aws_session_token

# Jira (optional)
JIRA_HOST=your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token_here

# DEPRECATED: GitHub PAT is no longer used for sync
# GitHub tokens are now obtained via OAuth. Remove this if present.
# GITHUB_TOKEN=your_github_token_here
