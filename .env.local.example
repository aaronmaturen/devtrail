# Database (use absolute path for Next.js API routes)
# Replace /path/to/project with your actual project directory
DATABASE_URL="file:/path/to/project/devtrail/prisma/dev.db"

# AWS Bedrock (Claude is invoked via Bedrock; no Anthropic API key needed)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# Optional: required when using STS / assumed-role / MFA temporary credentials
# AWS_SESSION_TOKEN=your_aws_session_token

# GitHub
GITHUB_TOKEN=your_github_token_here

# Jira (optional)
JIRA_HOST=your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token_here
